# Port sur lequel le serveur Express va ecouter
PORT=5000

# URI de connexion MongoDB
# - Local : mongodb://127.0.0.1:27017/mini-facebook
# - Atlas (cloud gratuit) : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mini-facebook
MONGO_URI=mongodb://127.0.0.1:27017/mini-facebook

# Cle secrete utilisee pour signer les tokens JWT (mets une longue chaine aleatoire en production)
JWT_SECRET=remplace_moi_par_une_chaine_secrete_longue_et_aleatoire

# Duree de validite du token JWT
JWT_EXPIRES_IN=7d

# URL du frontend (utilisee pour la config CORS et Socket.io)
CLIENT_URL=http://localhost:3000
